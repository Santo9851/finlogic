# ── Finlogic Capital — Production Environment Variables ───────────────────────
# Copy this file to .env and fill in real values.
# IMPORTANT: Values in this file will be baked into the Docker build for the frontend.

# ── Django Backend ────────────────────────────────────────────────────────────
# Generate a new one for production!
DJANGO_SECRET_KEY=django-insecure-replace-this-with-a-very-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# External PostgreSQL Database
DB_NAME=finlogic
DB_USER=admin
DB_PASSWORD=your_secure_password
DB_HOST=your_db_host_ip
DB_PORT=5432

# Redis (Internal Docker container)
REDIS_URL=redis://finlogic_redis:6379/1

# AI Scoring
GEMINI_API_KEY=your-gemini-api-key-here

# ── Next.js Frontend ──────────────────────────────────────────────────────────
# This URL must be the PUBLIC URL of your API (how the browser sees it).
# Examples:
# - Production: https://yourdomain.com/api/
# - Local Test: http://localhost:8000/api/
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/

# ── Celery & Other ────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin-password-123
